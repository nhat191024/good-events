# Ignore vendor directory (will be installed inside container)
vendor/

# Ignore node_modules (will be installed inside container)
node_modules/

# Ignore storage files (will be mounted as volume)
storage/logs/*
storage/framework/cache/*
storage/framework/sessions/*
storage/framework/views/*

# Ignore bootstrap cache
bootstrap/cache/*

# Ignore environment files
.env
.env.local
.env.*.local

# Ignore git
.git/
.gitignore

# Ignore development files
.vscode/
.idea/
*.log

# Ignore Docker files themselves
dockerfile
docker-compose.yml
.dockerignore

# Ignore documentation
README.md
docs/

# Ignore tests (not needed in production image)
tests/

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore build outputs (will be generated inside container stages)
public/build/
bootstrap/ssr/
